# TruAgent environment template.
# Copy this file to ".env" and fill in the values you need.
# The real ".env" is gitignored and must never be committed.

# --- AI assistant (OpenAI) ---
# Get a key at https://platform.openai.com/api-keys
# Leave blank to keep the AI assistant dormant.
OPENAI_API_KEY=

# --- Security secrets ---
# SESSION_SECRET signs login tokens. Generate a strong random value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=
# Shared secrets that Zapier must include so only your webhooks are accepted.
ZAPIER_SECRET=
QUICKBOOKS_SECRET=

# Inbound-door + scheduler shared secrets (sibling apps F1/F2/F3 + cron F4).
# Each falls back to an INSECURE placeholder if blank — set a strong value
# (python -c "import secrets; print(secrets.token_urlsafe(48))") before connecting.
ALPHA_SECRET=
PRODUCTION_SECRET=
LEADS_SECRET=
CRON_SECRET=

# --- Integration webhook URLs (from Zapier) ---
# Leave blank to keep the related feature turned off (shows "not configured").
ROOFR_WEBHOOK_URL=
EMAIL_WEBHOOK_URL=
SMS_WEBHOOK_URL=
# Where to route documents for e-signature (DocuSign or a Zapier e-sign step).
ESIGN_WEBHOOK_URL=

# --- Local server port (optional; defaults to 5000) ---
PORT=5000
